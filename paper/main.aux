\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Compact SR heatmap for all four configurations across all eight benchmarks. Green = high SR, red = low SR. The Manual ``FAIL'' cell at $12{\times }12$ Expert and the two LLM-Flax\xspace  cells at SR~1.000 are the most salient features. The PLOI row is uniformly lower than both Manual and LLM-Flax\xspace  , confirming that rules—not the GNN scorer—drive the performance advantage.}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:sr_heatmap}{{5}{6}{Compact SR heatmap for all four configurations across all eight benchmarks. Green = high SR, red = low SR. The Manual ``FAIL'' cell at $12{\times }12$ Expert and the two \method cells at SR~1.000 are the most salient features. The PLOI row is uniformly lower than both Manual and \method , confirming that rules—not the GNN scorer—drive the performance advantage}{figure.caption.7}{}}
\newlabel{fig:sr_heatmap@cref}{{[figure][5][]5}{[1][5][]6}}
