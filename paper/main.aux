\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Success rate vs.\ difficulty (Manual vs.\ LLM-Flax\xspace  ) across all grid sizes. Shaded columns mark benchmarks where LLM-Flax\xspace  outperforms Manual. The crossover is non-monotonic and stacking-density-driven: Manual wins on stacking-heavy tasks (all 10$\times $10, 12$\times $12 Medium/Hard, 15$\times $15 Medium), while LLM-Flax\xspace  dominates on navigation-heavy tasks (12$\times $12 Expert: SR 1.000 vs.\ ALL FAIL; 15$\times $15 Hard: 1.000 vs.\ 0.900).}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:sr_scale}{{3}{5}{Success rate vs.\ difficulty (Manual vs.\ \method ) across all grid sizes. Shaded columns mark benchmarks where \method outperforms Manual. The crossover is non-monotonic and stacking-density-driven: Manual wins on stacking-heavy tasks (all 10$\times $10, 12$\times $12 Medium/Hard, 15$\times $15 Medium), while \method dominates on navigation-heavy tasks (12$\times $12 Expert: SR 1.000 vs.\ ALL FAIL; 15$\times $15 Hard: 1.000 vs.\ 0.900)}{figure.caption.4}{}}
\newlabel{fig:sr_scale@cref}{{[figure][3][]3}{[1][4][]5}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces LLM-Flax\xspace  pipeline on a $10{\times }10$ hard MazeNamo problem (problem~16, 163 objects). (a)~Full problem with all objects. (b)~Zero-shot LLM relevance scores assigned to each object (Stage~3): goal scores 1.00, nearby obstacles score 0.5--0.9, distant objects score low. (c)~After Step~1 threshold-based pruning: 21 objects excluded (grey), 142 retained at threshold 0.478. (d)~Step~2 relaxed sub-problem: light boxes removed via relaxation rules, yielding a rough plan. (e)~Step~3 complementary expansion: object pairs with structural constraints restored. (f)~Final plan of length 39 found in 0.8\,s.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:pipeline}{{4}{5}{\method pipeline on a $10{\times }10$ hard MazeNamo problem (problem~16, 163 objects). (a)~Full problem with all objects. (b)~Zero-shot LLM relevance scores assigned to each object (Stage~3): goal scores 1.00, nearby obstacles score 0.5--0.9, distant objects score low. (c)~After Step~1 threshold-based pruning: 21 objects excluded (grey), 142 retained at threshold 0.478. (d)~Step~2 relaxed sub-problem: light boxes removed via relaxation rules, yielding a rough plan. (e)~Step~3 complementary expansion: object pairs with structural constraints restored. (f)~Final plan of length 39 found in 0.8\,s}{figure.caption.5}{}}
\newlabel{fig:pipeline@cref}{{[figure][4][]4}{[1][4][]5}}
